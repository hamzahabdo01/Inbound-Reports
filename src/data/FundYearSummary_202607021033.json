{
"WITH FundYearSummary AS\r\n(\r\n    SELECT\r\n        YEAR(PO_DOCUMENT_DATE) AS PROCUREMENT_YEAR,\r\n        FUND,\r\n        COUNT(DISTINCT EBELN)\r\n            AS PURCHASE_ORDER_COUNT,\r\n        COUNT\r\n        (\r\n            DISTINCT CONCAT(EBELN, '|', EBELP)\r\n        ) AS PURCHASE_ORDER_ITEM_COUNT,\r\n        COUNT(DISTINCT SUPPLIER_NUMBER)\r\n            AS DISTINCT_SUPPLIER_COUNT,\r\n        COUNT(DISTINCT MATERIAL_NUMBER)\r\n            AS DISTINCT_MATERIAL_COUNT,\r\n        SUM(ALLOCATED_ITEM_VALUE_ETB)\r\n            AS PROCUREMENT_VALUE_ETB,\r\n        SUM\r\n        (\r\n            CASE\r\n                WHEN ALLOCATED_ITEM_VALUE_ETB IS NULL\r\n                THEN 1\r\n                ELSE 0\r\n            END\r\n        ) AS ALLOCATION_ROWS_WITHOUT_ETB_VALUE,\r\n        SUM\r\n        (\r\n            CASE\r\n                WHEN ALLOCATION_QUALITY_STATUS <>\r\n                     'VALID_100_PERCENT'\r\n                THEN 1\r\n                ELSE 0\r\n            END\r\n        ) AS ALLOCATION_WARNING_ROW_COUNT,\r\n        MIN(PO_DOCUMENT_DATE)\r\n            AS EARLIEST_PO_DATE,\r\n        MAX(PO_DOCUMENT_DATE)\r\n            AS LATEST_PO_DATE\r\n    FROM ERP.vw_POFundingAllocationBase\r\n    WHERE PO_DOCUMENT_DATE IS NOT NULL\r\n    GROUP BY\r\n        YEAR(PO_DOCUMENT_DATE),\r\n        FUND\r\n)\r\nSELECT\r\n    PROCUREMENT_YEAR,\r\n    FUND,\r\n    PURCHASE_ORDER_COUNT,\r\n    PURCHASE_ORDER_ITEM_COUNT,\r\n    DISTINCT_SUPPLIER_COUNT,\r\n    DISTINCT_MATERIAL_COUNT,\r\n    CAST\r\n    (\r\n        PROCUREMENT_VALUE_ETB\r\n        AS decimal(28,2)\r\n    ) AS PROCUREMENT_VALUE_ETB,\r\n    CAST\r\n    (\r\n        100.0\r\n        * PROCUREMENT_VALUE_ETB\r\n        \/ NULLIF\r\n          (\r\n              SUM(PROCUREMENT_VALUE_ETB)\r\n                  OVER\r\n                  (\r\n                      PARTITION BY PROCUREMENT_YEAR\r\n                  ),\r\n              0\r\n          )\r\n        AS decimal(9,2)\r\n    ) AS PERCENT_OF_YEAR_TOTAL_VALUE,\r\n    ALLOCATION_ROWS_WITHOUT_ETB_VALUE,\r\n    ALLOCATION_WARNING_ROW_COUNT,\r\n    EARLIEST_PO_DATE,\r\n    LATEST_PO_DATE,\r\n    'ETB' AS REPORTING_CURRENCY\r\nFROM FundYearSummary\r\nORDER BY\r\n    PROCUREMENT_YEAR,\r\n    PROCUREMENT_VALUE_ETB DESC;": [
